# Copie este arquivo para .env e preencha com seus valores reais
# O arquivo .env NUNCA deve ser commitado no Git

# ── Dados ─────────────────────────────────────────────────────────────────
DATA_URL=https://storage.googleapis.com/download.tensorflow.org/data/creditcard.csv

# ── Modelo ────────────────────────────────────────────────────────────────
# Threshold otimizado pela análise de custo (gerado automaticamente)
DECISION_THRESHOLD=0.30

# Custos financeiros para a análise de threshold
COST_FALSE_NEGATIVE=500   # R$ perdidos por fraude não detectada
COST_FALSE_POSITIVE=10    # R$ de custo por bloqueio indevido

# ── API ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── ngrok (para deploy no Colab) ──────────────────────────────────────────
# Obtenha seu token em https://ngrok.com
NGROK_TOKEN=seu_token_aqui
